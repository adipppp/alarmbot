# Discord Bot Configuration
# Your Discord bot token - get this from Discord Developer Portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# PostgreSQL Database Configuration for Docker
# Database user credentials
DB_USER=alarmbot
DB_PASSWORD=your_secure_password_here

# Database name
DB_NAME=alarmbot

# Database port (exposed on host machine)
# Note: Inside Docker containers, the database is accessible at db:5432
DB_PORT=5432

# Optional: For local development without Docker, use this format:
# DATABASE_URL=postgresql://user@localhost:5432/alarmbot?schema=public
